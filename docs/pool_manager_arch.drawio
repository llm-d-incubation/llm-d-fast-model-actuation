        <mxCell id="launcher" value="&lt;b&gt;Launcher Pod&lt;/b&gt;&lt;br&gt;- Receives POST from controller with server patch&lt;br&gt;- Creates vLLM inference server (IS Pod)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;align=left;spacingLeft=2;" parent="1" vertex="1">
