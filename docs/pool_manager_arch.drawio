          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="controller" value="&lt;b&gt;Dual-Pod Controller&lt;/b&gt;&lt;br&gt;Watches ISR Pods&lt;br&gt;Requests launcher pod from Pool Manager passing in server patch&lt;div&gt;&lt;br/&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;align=left;spacingLeft=2;" parent="1" vertex="1">
