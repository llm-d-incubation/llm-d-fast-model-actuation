        <mxCell id="poolmanager" value="&lt;b&gt;Pool Manager&lt;/b&gt;&lt;br&gt;- Maintains N launcher pods&lt;br&gt;- Registers launcher pods to GIE InferencePool&lt;br&gt;- Adds server-running pod annotations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;align=left;spacingLeft=2;" parent="1" vertex="1">
